{
  "manifest_version": 3,
  "name": "Findmap Extension",
  "version": "0.0.1",
  "description": "Cào dữ liệu Google Maps — tự kết nối domain Findmap (vd. https://app.findmap.vn)",
  "permissions": [
    "activeTab",
    "tabs",
    "windows",
    "storage",
    "scripting",
    "geolocation",
    "alarms"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Findmap Extension"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*"
      ],
      "js": [
        "grid.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "web-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
