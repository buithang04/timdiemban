{
  "manifest_version": 3,
  "name": "Findmap Extension",
  "version": "0.0.4",
  "permissions": [
    "activeTab",
    "tabs",
    "windows",
    "storage",
    "scripting",
    "geolocation",
    "alarms"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://findmap.vn/*",
    "https://www.findmap.vn/*",
    "https://app.findmap.vn/*",
    "https://*.findmap.vn/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Findmap Extension"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*"
      ],
      "js": [
        "place-fields.js",
        "grid.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://findmap.vn/*",
        "https://www.findmap.vn/*",
        "https://app.findmap.vn/*",
        "https://*.findmap.vn/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "web-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
